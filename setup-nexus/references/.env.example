# Nexus 生产配置
# 复制为 .env 并按实际情况修改

# 域名配置（dnsmasq 解析，单机可用 localhost）
NEXUS_HOSTNAME=nexus.renew.com

# 端口配置
NEXUS_PORT=8081
NEXUS_DOCKER_PORT=8082

# JVM 参数（根据服务器内存调整）
NEXUS_JVM_MIN_HEAP=1g
NEXUS_JVM_MAX_HEAP=2g
NEXUS_DIRECT_MEMORY=2g

# 首次密码通过以下命令获取：
# docker exec tech-nexus cat /nexus-data/admin.password
