# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
# 本文件中需替换的密码字段及对应标签：
#   MONGO_INITDB_ROOT_PASSWORD → MgoRoot_{16位随机}
#   MONGO_APP_PASSWORD → MgoApp_{16位随机}
#   MONGO_EXPORTER_PASSWORD → MgoExp_{16位随机}
# 示例：MgoRoot_aB3kP7mN9xQ2wE5r
# 部署完成后密码记录在 env/mongodb.md

# MongoDB 生产环境配置
# 复制为 .env 并修改所有 CHANGE_ME_* 值

# ========== 部署环境 ==========
# 多环境部署：每个环境（dev/sit/fat/uat/prod）独立一套实例，复制此模板后修改 ENV 和密码
ENV=dev

# ========== 镜像与容器 ==========
MONGO_IMAGE=mongo:8.0
MONGO_PORT=27017

# ========== 认证凭据 ==========
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_MIN_16_CHARS
MONGO_APP_DATABASE=appdb
MONGO_APP_USER=appuser
MONGO_APP_PASSWORD=CHANGE_ME_APP_PASSWORD_MIN_16_CHARS

# ========== 资源限制 ==========
# 根据环境调整，以下为 dev 环境默认值
# dev/sit=1g, fat/uat=2g, prod=4g
MONGO_MEMORY_LIMIT=1g
MONGO_MEMORY_RESERVATION=256m

# ========== MongoDB 性能调优 ==========
# WiredTiger 缓存大小（建议为容器内存限制的 50%）
# dev/sit=0.5, fat/uat=1, prod=2
MONGO_CACHE_SIZE_GB=0.5
# 最大连接数
MONGO_MAX_CONNECTIONS=500
# 慢操作阈值（毫秒），超过此值的操作会被记录到 profiler
MONGO_SLOW_OP_THRESHOLD_MS=200

# ========== 日志轮转 ==========
MONGO_LOG_MAX_SIZE=100m
MONGO_LOG_MAX_FILE=5

# ========== Prometheus 指标导出（mongodb_exporter） ==========
MONGODB_EXPORTER_PORT=9216
MONGO_EXPORTER_USER=exporter
MONGO_EXPORTER_PASSWORD=CHANGE_ME_EXPORTER_PASSWORD
