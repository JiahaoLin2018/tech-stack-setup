# Loki 配置
# 复制此文件为 .env 并修改

# ===== 部署环境（B 类契约）=====
# nonprod = 非生产共用；prod = 生产独立
# 对应容器名：tech-loki-${ENV}，部署目录：/opt/tech-stack/loki-${ENV}/
ENV=nonprod

# ===== 多租户认证（生产强制开启）=====
# nonprod = false（开发调试便捷）；prod = true（生产环境多租户隔离 + 鉴权）
LOKI_AUTH_ENABLED=false

# ===== Alertmanager 地址（ruler 告警推送目标）=====
# ② 域级直连域名，写入 hosts.lan
ALERTMANAGER_HOST=alertmanager-nonprod.renew.com   # prod 时改为 alertmanager-prod.renew.com
ALERTMANAGER_PORT=9093

# ==================== 网络 ====================
# Loki HTTP API 端口
LOKI_PORT=3100
# Loki gRPC 端口（集群通信 / 内部调用）
LOKI_GRPC_PORT=9096

# ==================== 存储与保留 ====================
# 数据保留时间（默认 7 天）
LOKI_RETENTION_PERIOD=168h
# Compactor 压缩间隔
LOKI_COMPACTION_INTERVAL=10m
# 保留删除延迟（防止误删正在查询的数据）
LOKI_RETENTION_DELETE_DELAY=2h

# ==================== 摄入限制 ====================
# 每租户每秒摄入速率上限（MB）
LOKI_INGESTION_RATE_MB=10
# 摄入突发大小（MB）
LOKI_INGESTION_BURST_SIZE_MB=20
# 每租户最大活跃日志流数
LOKI_MAX_STREAMS_PER_USER=10000
# 单次查询最大返回序列数
LOKI_MAX_QUERY_SERIES=500

# ==================== 缓存 ====================
# 查询结果缓存大小（MB）
LOKI_CACHE_MAX_SIZE_MB=100

# ==================== 资源限制 ====================
# 容器内存上限
LOKI_MEMORY_LIMIT=1g

# ==================== 日志级别 ====================
# Loki 服务端日志级别（debug / info / warn / error）
LOKI_LOG_LEVEL=info
