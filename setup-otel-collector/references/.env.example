# OpenTelemetry Collector 配置
# 复制此文件为 .env 并修改

# ===== 部署环境（B 类契约）=====
# nonprod = 非生产共用；prod = 生产独立
# 对应容器名：tech-otel-collector-${ENV}，部署目录：/opt/tech-stack/otel-collector-${ENV}/
ENV=nonprod

# 端口映射
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8888  # Collector 自身运行指标（Prometheus 采集用）

# 后端地址（② 域级直连域名，写入 hosts.lan；nonprod/prod 分别指向对应实例）
# 部署前确保 setup-dns 已部署且 hosts.lan 已配置对应 IP 映射
TEMPO_HOST=tempo-nonprod.renew.com   # prod 时改为 tempo-prod.renew.com
TEMPO_GRPC_PORT=14317
LOKI_HOST=loki-nonprod.renew.com     # prod 时改为 loki-prod.renew.com
LOKI_PORT=3100

# OTel Collector 注入的环境标识（写入 deployment.environment Resource Attribute）
# 注意：这是域级标识（nonprod/prod），仅作为兜底值
# - 应用通过 OTEL_RESOURCE_ATTRIBUTES=deployment.environment={env} 传入具体环境（dev/sit/fat/uat/prod）
# - Collector 配置 action: insert，只在数据中不存在时才插入，不会覆盖应用传来的值
# - 例如：应用传 deployment.environment=fat，Collector 保留 fat；未传则使用此 DEPLOYMENT_ENV 值
DEPLOYMENT_ENV=nonprod   # prod 时改为 prod

# 资源限制
OTEL_MEMORY_LIMIT=512m
