# Tempo 配置
# 复制此文件为 .env 并修改

# ===== 部署环境（B 类契约）=====
# nonprod = 非生产共用；prod = 生产独立
# 对应容器名：tech-tempo-${ENV}，部署目录：/opt/tech-stack/tempo-${ENV}/
ENV=nonprod

# ============ 端口映射 ============
TEMPO_HTTP_PORT=3200
# OTLP 宿主机端口使用 14317/14318，避免与同机 OTel Collector 的 4317/4318 冲突
TEMPO_OTLP_GRPC_PORT=14317
TEMPO_OTLP_HTTP_PORT=14318
TEMPO_ZIPKIN_PORT=9411

# ============ 后端地址（② 域级直连域名，写入 hosts.lan）============
# Tempo metrics_generator → remote_write → Prometheus
# prod 部署时改为 prometheus-prod.renew.com
PROMETHEUS_HOST=prometheus-nonprod.renew.com
PROMETHEUS_PORT=9090

# ============ 数据保留 ============
# 保留 7 天
TEMPO_RETENTION=168h

# ============ 资源限制 ============
TEMPO_MEMORY_LIMIT=2g
