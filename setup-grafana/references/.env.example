# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
# 本文件中需替换的密码字段及对应标签：
#   GRAFANA_ADMIN_PASSWORD → GrfAdm_{16位随机}
# 示例：GrfAdm_aB3kP7mN9xQ2wE5r
# 部署完成后密码记录在 env/grafana.md

# Grafana 生产配置
# 复制此文件为 .env 并修改所有 CHANGE_ME 占位符

# Grafana 管理员账号
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD_MIN_8_CHARS

# ===== 部署环境（B 类契约）=====
# nonprod = 非生产共用；prod = 生产独立
# 对应容器名：tech-grafana-${ENV}，部署目录：/opt/tech-stack/grafana-${ENV}/
ENV=nonprod

# 数据源地址（② 域级直连域名，写入 hosts.lan；nonprod/prod 分别指向对应实例）
# 部署前确保 setup-dns 已部署且 hosts.lan 已配置对应 IP 映射
PROMETHEUS_HOST=prometheus-nonprod.renew.com   # prod 时改为 prometheus-prod.renew.com
PROMETHEUS_PORT=9090
TEMPO_HOST=tempo-nonprod.renew.com             # prod 时改为 tempo-prod.renew.com
TEMPO_PORT=3200
LOKI_HOST=loki-nonprod.renew.com               # prod 时改为 loki-prod.renew.com
LOKI_PORT=3100

# 端口映射
GRAFANA_PORT=3000

# Web UI 访问 URL（② 域级共用 UI 域名，通过 infra-nginx 反代）
# nonprod-ui: http://grafana-nonprod-ui.renew.com → infra-nginx → :3000
# prod-ui:    http://grafana-prod-ui.renew.com    → infra-nginx → :3000
GRAFANA_ROOT_URL=http://grafana-nonprod-ui.renew.com   # prod 时改为 http://grafana-prod-ui.renew.com
