# infra-nginx 环境变量配置
# 部署前必须根据实际环境替换所有 CHANGE_ME_* 占位符
# nginx 配置中的 ${VAR} 由 actions/start.md 中的 Python 脚本在本地替换后上传

# ========== ① 全局唯一服务 ==========

# GitLab（HTTP 反代 :80→:8929；SSH TCP 透传 :2222）
GITLAB_HOST=CHANGE_ME_GITLAB_IP
GITLAB_HTTP_PORT=8929
GITLAB_SSH_PORT=2222

# Nexus（HTTP 反代 :80→:8081；Docker Registry TCP 透传 :8082）
NEXUS_HOST=CHANGE_ME_NEXUS_IP
NEXUS_HTTP_PORT=8081
NEXUS_DOCKER_PORT=8082

# Harbor（HTTP 反代 :80→:8880）
HARBOR_HOST=CHANGE_ME_HARBOR_IP
HARBOR_PORT=8880

# dnsmasq Web UI（HTTP 反代 :80→:5380）
DNS_HOST=CHANGE_ME_DNS_IP
DNS_WEB_PORT=5380

# ========== ③ 非生产独有 — Apollo Portal ==========
# Apollo Portal Web UI（HTTP 反代 :80→:8070）
# 注意：非生产 Config/Admin Service 端口 :8601-8604 也在此机器上
APOLLO_HOST=CHANGE_ME_APOLLO_NONPROD_IP
APOLLO_PORTAL_PORT=8070

# ========== ④ Apollo Config Service（各环境独立端口）==========
# 非生产 Config Service 与 APOLLO_HOST 同机
# 生产 Config Service 在独立生产网段机器
APOLLO_PROD_HOST=CHANGE_ME_APOLLO_PROD_IP

# ========== ② 域级共用 UI — 可观测性（nonprod/prod 各一套）==========

# Grafana Web UI（HTTP 反代 :80→:3000）
GRAFANA_NONPROD_HOST=CHANGE_ME_GRAFANA_NONPROD_IP
GRAFANA_PROD_HOST=CHANGE_ME_GRAFANA_PROD_IP
GRAFANA_PORT=3000

# Prometheus Web UI（HTTP 反代 :80→:9090）
PROMETHEUS_NONPROD_HOST=CHANGE_ME_PROMETHEUS_NONPROD_IP
PROMETHEUS_PROD_HOST=CHANGE_ME_PROMETHEUS_PROD_IP
PROMETHEUS_PORT=9090

# Alertmanager Web UI（HTTP 反代 :80→:9093）
ALERTMANAGER_NONPROD_HOST=CHANGE_ME_ALERTMANAGER_NONPROD_IP
ALERTMANAGER_PROD_HOST=CHANGE_ME_ALERTMANAGER_PROD_IP
ALERTMANAGER_PORT=9093

# ========== ④ 环境级 Web UI — Consul（5 环境独立）==========
# Consul UI HTTP 反代 :80→:8500
# 注意：Consul 数据端口（:8500 API）由 Pod 通过 consul-{env}.renew.com 直连，不经 nginx
CONSUL_DEV_HOST=CHANGE_ME_CONSUL_DEV_IP
CONSUL_SIT_HOST=CHANGE_ME_CONSUL_SIT_IP
CONSUL_FAT_HOST=CHANGE_ME_CONSUL_FAT_IP
CONSUL_UAT_HOST=CHANGE_ME_CONSUL_UAT_IP
CONSUL_PROD_HOST=CHANGE_ME_CONSUL_PROD_IP
CONSUL_PORT=8500

# ========== ④ 环境级 Web UI — RabbitMQ（5 环境独立）==========
# RabbitMQ Management UI HTTP 反代 :80→:15672
# 注意：RabbitMQ AMQP（:5672）由 Pod 通过 rabbitmq-{env}.renew.com 直连，不经 nginx
RABBITMQ_DEV_HOST=CHANGE_ME_RABBITMQ_DEV_IP
RABBITMQ_SIT_HOST=CHANGE_ME_RABBITMQ_SIT_IP
RABBITMQ_FAT_HOST=CHANGE_ME_RABBITMQ_FAT_IP
RABBITMQ_UAT_HOST=CHANGE_ME_RABBITMQ_UAT_IP
RABBITMQ_PROD_HOST=CHANGE_ME_RABBITMQ_PROD_IP
RABBITMQ_MGMT_PORT=15672

# ========== 业务流量 — K3s Traefik 内网直达（nonprod / prod 双 K3s 集群）==========
# *.dev|sit|fat|uat.web/api.renew.com → 非生产 K3s Traefik
# *.prod.web/api.renew.com           → 生产 K3s Traefik
# 必须使用 K3s 节点的宿主机实际 IP；不能用 127.0.0.1
# （K3s svclb 通过 iptables DNAT 转发端口，不在宿主机 loopback 监听）
K3S_NONPROD_TRAEFIK_HOST=CHANGE_ME_K3S_NONPROD_TRAEFIK_IP
K3S_PROD_TRAEFIK_HOST=CHANGE_ME_K3S_PROD_TRAEFIK_IP
K3S_TRAEFIK_PORT=8083
