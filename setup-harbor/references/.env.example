# Harbor 部署参数
# 这些变量通过 envsubst 自动填充到 harbor.yml 中
#
# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
#   HARBOR_ADMIN_PASSWORD → HbrAdm_{16位随机}
#   HARBOR_DB_PASSWORD → HbrDb_{16位随机}
# 示例：HbrAdm_aB3kP7mN9xQ2wE5r
#
# 部署完成后密码记录在 env/harbor.md

HARBOR_HOSTNAME=harbor.renew.com
HARBOR_HTTP_PORT=8880
HARBOR_HTTPS_PORT=443
HARBOR_ADMIN_PASSWORD=CHANGE_ME_HARBOR_ADMIN_PASSWORD_MIN_8_CHARS
HARBOR_DB_PASSWORD=CHANGE_ME_HARBOR_DB_PASSWORD_MIN_16_CHARS
HARBOR_DATA_DIR=/opt/tech-stack/harbor/data
HARBOR_VERSION=v2.12.0

# 数据库账号（PostgreSQL 内置）
# Harbor 使用 PostgreSQL 内置的 postgres 用户，无需单独创建
# 此处仅作记录，实际密码在 HARBOR_DB_PASSWORD
HARBOR_DB_USER=postgres
HARBOR_DB_NAME=registry

# Docker 客户端 insecure-registries 配置说明
# ============================================
# Harbor 使用 HTTP 时，Docker 客户端需配置 insecure-registries 才能访问
#
# 推荐配置（无端口号）：
#   {"insecure-registries": ["harbor.renew.com"]}
#
# 优势：
#   - 同时支持 harbor.renew.com（nginx 代理 :80）和 harbor.renew.com:8880（直连）
#   - 配置简洁，与浏览器访问方式一致
#
# 端口 8880 的来源：
#   - HARBOR_HTTP_PORT=8880 定义了 Harbor 实际监听端口
#   - infra-nginx 通过 proxy_pass 将 harbor.renew.com:80 转发到 harbor.renew.com:8880
#   - 两者都能访问 Harbor，只是路径不同（nginx 代理 vs 直连）
