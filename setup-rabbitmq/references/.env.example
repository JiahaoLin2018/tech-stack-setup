# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
# 本文件中需替换的密码字段及对应标签：
#   RABBITMQ_PASSWORD → RmqAdm_{16位随机}
# 示例：RmqAdm_aB3kP7mN9xQ2wE5r
# 部署完成后密码记录在 env/rabbitmq.md

# RabbitMQ 生产环境配置
# 复制为 .env 并修改所有 CHANGE_ME_* 值

# 部署环境（dev|sit|fat|uat|prod）
ENV=dev

# 账号与 vhost
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD_MIN_16_CHARS
RABBITMQ_VHOST=/

# 端口
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692

# 资源限制
# 根据环境调整，以下为 dev 环境默认值
# dev/sit=512m, fat/uat=1g, prod=2g
RABBITMQ_MEMORY_LIMIT=512m
RABBITMQ_MEMORY_RESERVATION=128m

# 时区
TZ=Asia/Shanghai
