# GitLab Runner 配置
# 部署完成后相关信息记录在 env/gitlab-runner.md

# ========== 集群环境（B 类契约）==========
# 由 --env 参数自动写入，通常无需手动修改
# 允许值：nonprod（默认）| prod
RUNNER_ENV=nonprod
# Runner tag，由 --env 推导：nonprod → non-prod，prod → prod
# Pipeline 通过 tags: [non-prod] 或 tags: [prod] 选择对应 Runner
RUNNER_TAG=non-prod

# ========== GitLab 连接配置 ==========
# GitLab 实例地址
GITLAB_URL=http://gitlab.renew.com
# Runner 注册 Token（从 GitLab 获取：Settings → CI/CD → Runners → New Project Runner）
# 注意：这是 project token 或 group token，格式如 glrt-xxxxxxxx
RUNNER_REGISTRATION_TOKEN=CHANGE_ME_FROM_GITLAB_SETTINGS

# ========== CI Job 执行环境配置 ==========
# Harbor 镜像仓库密码（app.sh 和基础镜像推送使用）
HARBOR_PASSWORD=CHANGE_ME_HARBOR_PASSWORD
# Nexus 私服密码（settings.xml 使用）
NEXUS_PASSWORD=CHANGE_ME_NEXUS_PASSWORD

# ========== Runner 配置 ==========
# Runner 名称（显示在 GitLab 中）
RUNNER_NAME=gitlab-runner-01
# 并发作业数（注册后通过 sed 写入 config.toml，register 命令不接受此参数）
RUNNER_CONCURRENT=2
# 注意：RUNNER_TAGS / RUNNER_RUN_UNTAGGED / RUNNER_LOCKED 等在 GitLab UI 中配置
# Runner 18.x 的 register 命令不接受这些参数（需在 GitLab → Settings → CI/CD → Runners 编辑）

# ========== Docker Executor 配置 ==========
# 默认镜像（CI 作业未指定镜像时使用）
RUNNER_DOCKER_IMAGE=maven:3.9-eclipse-temurin-21
# 是否拉取最新镜像
RUNNER_DOCKER_PULL_POLICY=if-not-present
# 是否启用 privileged 模式（true 用于 Docker-in-Docker，默认 false 使用 socket 挂载）
RUNNER_DOCKER_PRIVILEGED=false
