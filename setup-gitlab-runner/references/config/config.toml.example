# GitLab Runner 配置文件示例
# 此文件在注册后自动生成，此处仅作参考
#
# 双 Runner 部署说明：
#   non-prod Runner（--env nonprod）：部署在非生产服务器，tag = non-prod
#   prod Runner   （--env prod）    ：部署在生产服务器，tag = prod
#
# Pipeline 按 tag 路由：
#   tags: [non-prod] → 触发非生产 Runner，部署到非生产 K3s（dev/sit/fat/uat namespace）
#   tags: [prod]     → 触发生产 Runner，部署到生产 K3s（prod namespace）

concurrent = 2
check_interval = 0
connection_max_age = "15m"
shutdown_timeout = 0

[session_server]
  session_timeout = 1800

# ============================================================
# 非生产 Runner 示例（--env nonprod，tag: non-prod）
# ============================================================
[[runners]]
  name = "gitlab-runner-nonprod"
  url = "http://gitlab.renew.com"
  id = 0
  token = "generated-after-register"
  token_obtained_at = 0001-01-01T00:00:00Z
  token_expires_at = 0001-01-01T00:00:00Z
  executor = "docker"
  # tag 在 GitLab UI 中配置（Settings → CI/CD → Runners → 编辑）：non-prod
  [runners.cache]
    MaxUploadedArchiveSize = 0
    [runners.cache.s3]
    [runners.cache.gcs]
    [runners.cache.azure]
  [runners.docker]
    image = "maven:3.9-eclipse-temurin-21"
    privileged = false
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    # 挂载说明：
    # - /cache: GitLab CI 缓存目录
    # - /var/run/docker.sock: CI 作业可构建/推送镜像（socket）
    # - /opt/tech-stack/cicd: app.sh、kubeconfig、kubectl-bin、jq-static、docker-static、settings.xml、opentelemetry-javaagent.jar
    # - kubectl-bin/jq-static/docker-static: 静态二进制，由 setup-gitlab-runner start 下载到 cicd 目录
    # - settings.xml: Maven 配置（Nexus 私服镜像）
    # - opentelemetry-javaagent.jar: OTel Java Agent（Spring Boot 2.x 兜底方案）
    #   ⚠️ 不要挂载 /usr/local/bin/kubectl（K3s symlink）或 /usr/bin/jq（动态链接）
    volumes = [
      "/cache",
      "/var/run/docker.sock:/var/run/docker.sock",
      "/opt/tech-stack/cicd:/opt/tech-stack/cicd:ro",
      "/opt/tech-stack/cicd/kubectl-bin:/usr/local/bin/kubectl:ro",
      "/opt/tech-stack/cicd/jq-static:/usr/local/bin/jq:ro",
      "/opt/tech-stack/cicd/docker-static:/usr/local/bin/docker:ro",
      "/opt/tech-stack/cicd/settings.xml:/root/.m2/settings.xml:ro",
      "/opt/tech-stack/cicd/opentelemetry-javaagent.jar:/opt/otel/opentelemetry-javaagent.jar:ro"
    ]
    pull_policy = ["if-not-present"]

# ============================================================
# 生产 Runner 示例（--env prod，tag: prod）
# 部署在生产服务器，使用生产 K3s kubeconfig
# ============================================================
