# Prometheus + Alertmanager 配置
# 复制此文件为 .env 并根据实际环境修改

# ===== 部署环境（B 类契约）=====
# nonprod = 非生产共用（采集 dev/sit/fat/uat 四套中间件）
# prod    = 生产独立（仅采集 prod 一套中间件）
# 对应容器名：tech-prometheus-${ENV} / tech-alertmanager-${ENV}
# 对应部署目录：/opt/tech-stack/prometheus-${ENV}/
ENV=nonprod

# ===== Prometheus 存储 =====
PROMETHEUS_RETENTION=30d
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
