# setup-k3s 配置
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ========== DNS 配置 ==========
# dnsmasq 服务器 IP（CoreDNS 转发目标）
# 由 setup-dns 部署后填写，见 env/dns.md
DNS_SERVER_IP=CHANGE_ME_DNS_SERVER_IP

# ========== 集群环境 ==========
# 集群类型：nonprod（dev/sit/fat/uat）或 prod
# 通常由 --env 参数传入，也可在此设置默认值
K3S_ENV=nonprod

# ========== SSH 配置（远程部署时使用）==========
# 目标 K3s 节点 IP
# K3S_HOST=<K3S_NODE_IP>
# SSH 用户名（默认: root）
# SSH_USER=root
# SSH 端口（默认: 22）
# SSH_PORT=22
# SSH 密码（与 SSH_KEY_PATH 二选一）
# SSH_PASSWORD=CHANGE_ME_SSH_PASSWORD
# SSH 密钥路径（与 SSH_PASSWORD 二选一，推荐）
# SSH_KEY_PATH=~/.ssh/id_rsa
