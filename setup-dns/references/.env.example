# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
# 本文件中需替换的密码字段及对应标签：
#   DNS_WEB_PASSWORD → DnsAdm_{16位随机}
# 示例：DnsAdm_aB3kP7mN9xQ2wE5r
# 部署完成后密码记录在 env/dns.md

# dnsmasq 局域网 DNS 配置
# 复制为 .env 并按实际情况修改
# dnsmasq 监听 :53（host 网络模式，固定，不可改）

# Web 管理界面端口（可选，用于调试）
DNS_WEB_PORT=5380
DNS_WEB_USER=admin
DNS_WEB_PASSWORD=CHANGE_ME_DNS_WEB_PASSWORD

# 上游 DNS（解析公网域名）— 按所在地域选择可达 DNS
#   国内默认: 114.114.114.114 / 223.5.5.5（阿里）
#   海外默认: 8.8.8.8 / 1.1.1.1（Cloudflare）
UPSTREAM_DNS_PRIMARY=114.114.114.114
UPSTREAM_DNS_SECONDARY=8.8.8.8

# infra-nginx 所在机器的 IP（用于 dnsmasq.conf 中的泛解析兜底 address=/renew.com/${INFRA_NGINX_IP}）
# 所有未在 hosts.lan 中精确定义的 *.renew.com 域名均解析到此 IP
INFRA_NGINX_IP=CHANGE_ME_INFRA_NGINX_IP
