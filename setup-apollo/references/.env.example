# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
# 本文件中需替换的密码字段及对应标签：
#   APOLLO_DB_ROOT_PASSWORD → ApoDb_{16位随机}
# 示例：ApoDb_aB3kP7mN9xQ2wE5r
# 部署完成后密码记录在 env/apollo-{nonprod|prod}.md

# ============================================================
# Apollo 配置中心 — 合并部署模式
#   --env nonprod: 10 容器（MySQL + Portal + dev/sit/fat/uat Config+Admin）
#   --env prod:    3  容器（MySQL_prod + Config_prod + Admin_prod）
# ============================================================

# ----- 数据库配置（nonprod 和 prod 部署均需配置，各自独立）-----
# MySQL root 密码，生产环境必须修改，最少 16 字符
APOLLO_DB_ROOT_PASSWORD=CHANGE_ME_APOLLO_DB_PASSWORD_MIN_16_CHARS
# MySQL 对外端口（默认 3307，避免与业务 MySQL 3306 冲突）
APOLLO_DB_PORT=3307

# ----- Config Service 端口（各环境独立，860x 系列）-----
# Spring Boot 客户端通过 apollo.meta=http://apollo-config-{env}.renew.com 连接（infra-nginx 代理）
APOLLO_CONFIG_PORT_DEV=8601
APOLLO_CONFIG_PORT_SIT=8602
APOLLO_CONFIG_PORT_FAT=8603
APOLLO_CONFIG_PORT_UAT=8604
APOLLO_CONFIG_PORT_PROD=8605

# ----- Admin Service 端口（各环境独立，861x 系列）-----
# 仅 Portal 使用，Spring Boot 客户端不直接连接
APOLLO_ADMIN_PORT_DEV=8611
APOLLO_ADMIN_PORT_SIT=8612
APOLLO_ADMIN_PORT_FAT=8613
APOLLO_ADMIN_PORT_UAT=8614
APOLLO_ADMIN_PORT_PROD=8615

# ----- Portal 端口（仅 nonprod 模式使用）-----
APOLLO_PORTAL_PORT=8070

# ----- Portal 环境列表（仅 nonprod 模式使用）-----
# Apollo 内置环境名，注意生产用 pro（不用 prod）
APOLLO_ENVS=dev,sit,fat,uat,pro

# ----- 生产 Config Service 跨网段地址（仅 nonprod 模式使用）-----
# Portal 通过此域名跨网段连接生产 Config Service（infra-nginx 代理）
# 阶段四完成后，Portal 中 PRO 环境状态变为可用
APOLLO_PRO_META=http://apollo-config-prod.renew.com

# ----- PortalDB 配置（仅 nonprod 模式使用）-----
# Portal 管理的环境列表（与 APOLLO_ENVS 保持一致）
APOLLO_PORTAL_ENVS=dev,sit,fat,uat,pro
# 组织结构 JSON（根据实际公司架构调整）
APOLLO_ORGANIZATIONS=[{"orgId":"TECH","orgName":"技术部"},{"orgId":"PRODUCT","orgName":"产品部"},{"orgId":"OPS","orgName":"运维部"}]
# 消费端 Token 盐值（安全必须，至少 32 字符）
APOLLO_CONSUMER_TOKEN_SALT=Ap0ll0_T0k3n_S4lt_2026_R3n3w_C0m#X9zKmPqVw
# 仅项目成员可查看配置的环境
APOLLO_CONFIG_VIEW_MEMBER_ONLY_ENVS=dev,sit,fat,uat,pro

# ----- ConfigDB 配置（nonprod 和 prod 均适用）-----
# 命名空间锁开关（生产环境建议 true，防止多人同时修改冲突）
APOLLO_NAMESPACE_LOCK_SWITCH=true

# ============================================================
# 各环境数据库说明
# nonprod 部署：ApolloPortalDB + ApolloConfigDB_dev/sit/fat/uat（共5个schema）
# prod 部署：   ApolloConfigDB_prod（1个schema，独立物理实例）
# ============================================================

# ============================================================
# Spring Boot 客户端接入说明
# Portal Web UI：http://apollo.renew.com（infra-nginx 代理 :80 → :8070）
# Config Service：http://apollo-config-{env}.renew.com（infra-nginx 代理）
#   dev: apollo.meta=http://apollo-config-dev.renew.com
#   sit: apollo.meta=http://apollo-config-sit.renew.com
#   fat: apollo.meta=http://apollo-config-fat.renew.com
#   uat: apollo.meta=http://apollo-config-uat.renew.com
#   prod: apollo.meta=http://apollo-config-prod.renew.com
# ============================================================

# ============================================================
# 安全加固（生产环境必做）
# 1. 修改 APOLLO_DB_ROOT_PASSWORD（至少 16 字符）
# 2. 首次登录后在 Portal 修改默认账号密码（默认 apollo/admin）
# 3. APOLLO_CONSUMER_TOKEN_SALT 已设置安全默认值，生产环境建议替换
# ============================================================
