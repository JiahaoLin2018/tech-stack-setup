# 多环境部署：每个环境（dev/sit/fat/uat/prod）独立一套实例，复制此模板后修改 ENV 和密码
# 密码生成规则：{服务缩写}{角色}_{16位随机大小写字母+数字}，总长 24-28 位
# 本文件中需替换的密码字段及对应标签：
#   MYSQL_ROOT_PASSWORD → MysRoot_{16位随机}
#   MYSQL_APP_PASSWORD → MysApp_{16位随机}
#   MYSQL_EXPORTER_PASSWORD → MysExp_{16位随机}
# 示例：MysRoot_aB3kP7mN9xQ2wE5r
# 部署完成后密码记录在 env/mysql.md

# MySQL 生产环境配置
# 复制为 .env 并修改所有 CHANGE_ME_* 值

# 部署环境（dev|sit|fat|uat|prod）
ENV=dev

# 认证
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_MIN_16_CHARS
MYSQL_APP_USER=appuser
MYSQL_APP_PASSWORD=CHANGE_ME_APP_PASSWORD_MIN_16_CHARS

# 数据库
MYSQL_DATABASE=appdb

# 网络
MYSQL_PORT=3306

# 时区
TZ=Asia/Shanghai

# 资源限制（根据环境调整，以下为 dev 环境默认值）
# dev/sit=1g, fat/uat=2g, prod=4g
MYSQL_MEMORY_LIMIT=1g
MYSQL_MEMORY_RESERVATION=256m
# InnoDB Buffer Pool（建议：容器内存的 70%）
# dev=700M, sit=700M, fat=1.4G, uat=1.4G, prod=2.8G
MYSQL_INNODB_BUFFER_POOL=700M

# Prometheus 指标导出（mysqld_exporter）
MYSQLD_EXPORTER_PORT=9104

# Exporter 专用监控用户密码（需与 conf/exporter.my.cnf 和 init/01_create_app_user.sql 中一致）
MYSQL_EXPORTER_PASSWORD=CHANGE_ME_EXPORTER_PASSWORD
